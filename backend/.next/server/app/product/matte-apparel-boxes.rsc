14:["$","section",null,{"className":" py-10","children":["$","div",null,{"className":"sm:max-w-8xl w-[95%] gap-3 flex flex-row items-center justify-between mx-auto","children":[["$","div",null,{"className":" w-6/12 mx-auto","children":[["$","div",null,{"className":"flex items-center mb-4 gap-2","children":[["$","div",null,{"className":"w-1 h-12 bg-linear-to-b from-[#EE334B] to-[#213554] rounded-full"}],["$","h2",null,{"className":"text-2xl sm:text-3xl font-bold text-[#213554] ","children":"Matte Apparel Boxes"}]]}],["$","p",null,{"className":"text-gray-600 text-sm sm:text-base max-w-6xl mx-auto  overflow-y-auto h-28 custom-scrollbar","children":"Let magnetic closure box packaging speak volumes about your products and brand with its luxurious appeal and elegance. The built-in magnet in the rigid stock ensures the boxes close and open easily without using tape or adhesive. You can pack all kinds of solid products in magnetic closure boxes, be they gifts or retail items. Customize them with sleek finishes to improve customers’ tactile and gifting experience!"}],["$","p",null,{"className":"my-5 font-semibold text-[#213554] text-xs sm:text-sm  tracking-wide","children":"More Than +5000 Satisfied Clients Worldwide"}],["$","$L1c",null,{}],["$","div",null,{"className":"","children":["$","img",null,{"src":"/assets/images/icon/sATISFIED-CLIENTS-BAGE.png","alt":"Satisfied Clients","className":" w-24"}]}],["$","div",null,{}]]}],["$","div",null,{"className":" w-4/12 mx-auto","children":["$","div",null,{"className":" w-full","children":["$","$L1d",null,{"src":"https://xcustompackaging.com/images/Tie-packaging-Boxes.webp","alt":"Matte Apparel Boxes","width":500,"height":500,"className":"  shadow-2xl w-full rounded-2xl"}]}]}]]}]}]
