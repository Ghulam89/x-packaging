{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-backend",
    "rootDir": ".",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"]
  },
  "include": [
    "lib/backend/**/*.ts",
    "lib/backend/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist-backend"
  ]
}
